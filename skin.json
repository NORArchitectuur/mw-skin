{
  "name": "NORA Skin",
  "version": "1.1.0",
  "author": "[https://www.archixl.nl Youri van den Bogert]",
  "license-name": "© 2016-2025 ArchiXL",
  "descriptionmsg": "nora-skin-desc",
  "type": "skin",
  "requires": {
    "MediaWiki": ">= 1.39.0",
    "extensions": {
      "SemanticMediaWiki": ">= 4.0"
    }
  },
  "AutoloadNamespaces": {
    "MediaWiki\\Skin\\NORA\\": "includes/"
  },
  "ValidSkinNames": {
    "nora": {
      "class": "MediaWiki\\Skin\\NORA\\Skin",
      "args": [
        {
          "name": "nora",
          "responsive": true,
          "templateDirectory": "skins/NORA/templates",
          "styles": [
            "skins.nora.styles",
            "skins.nora.upstream.styles"
          ],
          "scripts": [
            "skins.nora.scripts"
          ]
        }
      ]
    }
  },
  "ExtensionMessagesFiles": {
    "NORAMagic": "includes/Magic.php"
  },
  "MessagesDirs": {
    "NORA": [
      "i18n"
    ]
  },
  "Hooks": {
    "BeforePageDisplay": "MediaWiki\\Skin\\NORA\\Hooks\\BeforePageDisplay::onBeforePageDisplay",
    "ParserAfterTidy": "MediaWiki\\Skin\\NORA\\Hooks\\ParserAfterTidy::onParserAfterTidy",
    "SkinBuildSidebar": "MediaWiki\\Skin\\NORA\\Hooks\\SkinBuildSidebar::onSkinBuildSidebar",
    "SkinTemplateNavigation::Universal": "MediaWiki\\Skin\\NORA\\Hooks\\SkinTemplateNavigation__Universal::onSkinTemplateNavigation__Universal",
    "ParserFirstCallInit": "MediaWiki\\Skin\\NORA\\Hooks\\ParserFirstCallInit::onParserFirstCallInit"
  },
  "ResourceModules": {
    "skins.nora.styles": {
      "styles": [
        "dist/assets/mw-nora-components.css",
        "dist/assets/mw-templates.css",
        "dist/assets/mw-custom.css",
        "resources/css/main.less"
      ]
    },
    "skins.nora.smartcomments": {
      "styles": [
        "resources/css/smartcomments.less"
      ],
      "scripts": [
        "resources/js/smartcomments.js"
      ],
      "dependencies": [
        "ext.smartcomments"
      ]
    },
    "skins.nora.scripts": {
      "scripts": [
        "resources/js/information-panel.js",
        "resources/js/submenus.js",
        "resources/js/navigation.js",
        "resources/js/toc.js",
        "resources/js/export-rdf.js",
        "resources/js/icon-only.js",
        "resources/js/namespace-choice.js",
        "resources/js/responsive-tools.js"
      ],
      "messages": [
        "nora-information-panel-toggle-collapse",
        "nora-information-panel-toggle-expand",
        "nora-smart-comments-on",
        "nora-smart-comments-off"
      ],
      "dependencies": [
        "jquery.ui"
      ]
    }
  },
  "ResourceFileModulePaths": {
    "localBasePath": "",
    "remoteSkinPath": "NORA"
  },
  "config": {
    "NoraBackgroundCoverProperty": {
      "value": "Banner"
    },
    "NoraTocImageProperty": {
      "value": "Afbeelding rechts"
    },
    "NoraHelpTitle": {
      "value": "Help"
    }
  },
  "load_composer_autoloader": true,
  "manifest_version": 2
}
